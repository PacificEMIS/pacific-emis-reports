	<parameter name="CandidateID" class="java.lang.String">
		<defaultValueExpression><![CDATA["CE0C1AA3-CAD6-4B10-BBC0-0005832F50D1"]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT CAST(ROUND(100.0 * SUM(exciResult) / NULLIF(COUNT(*), 0), 0) AS int) AS FinalScore
FROM [dbo].[ExamCandidateItems]
WHERE excID = $P{CandidateID}]]>
	</queryString>
