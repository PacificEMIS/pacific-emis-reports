	<parameter name="Year" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2019]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[-- Precedence + JMP normalisation now live in warehouse.WashWaterCombined; a school is
-- "without water" when its resolved source is NO_WATER (one NO_WATER row per school).
-- Replaces TempWashCoreSurveyData + TempWaterSupply.
Select District as dName
, case when CurrentlyAvailable = 'Yes' then 'Schools without Water supply' else 'Schools with Water supply' end as WithAndWithoutWaterSupply
, count(distinct schNo) as 'noOfSchools'
from warehouse.WashWaterCombinedSchoolDimension
where SurveyYear = $P{Year} and WaterSource = 'NO_WATER'
group by District, case when CurrentlyAvailable = 'Yes' then 'Schools without Water supply' else 'Schools with Water supply' end]]>
	</queryString>
