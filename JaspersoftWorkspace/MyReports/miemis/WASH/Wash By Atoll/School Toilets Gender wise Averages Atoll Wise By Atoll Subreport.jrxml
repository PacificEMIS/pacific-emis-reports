	<subDataset name="Dataset1" uuid="e36bf2bc-4d66-42f5-a55c-1959fc516de5">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MIEMIS-OLD"/>
		<parameter name="Year" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[2019]]></defaultValueExpression>
		</parameter>
		<queryString language="SQL">
			<![CDATA[-- Repointed to warehouse.WashToiletsCombinedSchoolDimension (layered toilet refactor): instrument
-- precedence + ToiletType crosswalk live in the view, so the IF(inspection)/ELSE(census) is gone.
-- Ratios match the WASH dashboard (gender toilets use gender enrol; common toilets use total enrol).
-- Replaces TempWashCoreSurveyData + TempToiletsSurvey.
select District dName, genderCode, toiUse,
  SUM(TotalToilets) totalToilets,
  case when isnull(SUM(UsableToilets),0)=0 then 0 else isnull(SUM(Students),0)/SUM(UsableToilets) end Average,
  isnull(SUM(Students),0) Students
from (
  select District,'M' genderCode,'Boys' toiUse, TotalM TotalToilets, UsableM UsableToilets, EnrolM Students from warehouse.WashToiletsCombinedSchoolDimension where SurveyYear=$P{Year}
  union all select District,'F','Girls', TotalF, UsableF, EnrolF from warehouse.WashToiletsCombinedSchoolDimension where SurveyYear=$P{Year}
  union all select District,'C','Common', TotalC, UsableC, Enrol from warehouse.WashToiletsCombinedSchoolDimension where SurveyYear=$P{Year}
) x group by District, genderCode, toiUse]]>
		</queryString>
		<field name="dName" class="java.lang.String"/>
		<field name="genderCode" class="java.lang.String"/>
		<field name="toiUse" class="java.lang.String"/>
		<field name="Students" class="java.lang.Integer"/>
		<field name="totalToilets" class="java.lang.Integer"/>
		<field name="Average" class="java.lang.Integer"/>
		<variable name="TotalStudents" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{Students}]]></variableExpression>
		</variable>
		<variable name="TotalToilets" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{totalToilets}]]></variableExpression>
		</variable>
		<group name="Group1">
			<groupExpression><![CDATA[$F{dName}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="Year" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2019]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[-- Repointed to warehouse.WashToiletsCombinedSchoolDimension (layered toilet refactor): instrument
-- precedence + ToiletType crosswalk live in the view, so the IF(inspection)/ELSE(census) is gone.
-- Ratios match the WASH dashboard (gender toilets use gender enrol; common toilets use total enrol).
-- Replaces TempWashCoreSurveyData + TempToiletsSurvey.
select District dName, genderCode, toiUse,
  SUM(TotalToilets) totalToilets,
  case when isnull(SUM(UsableToilets),0)=0 then 0 else isnull(SUM(Students),0)/SUM(UsableToilets) end Average,
  isnull(SUM(Students),0) Students
from (
  select District,'M' genderCode,'Boys' toiUse, TotalM TotalToilets, UsableM UsableToilets, EnrolM Students from warehouse.WashToiletsCombinedSchoolDimension where SurveyYear=$P{Year}
  union all select District,'F','Girls', TotalF, UsableF, EnrolF from warehouse.WashToiletsCombinedSchoolDimension where SurveyYear=$P{Year}
  union all select District,'C','Common', TotalC, UsableC, Enrol from warehouse.WashToiletsCombinedSchoolDimension where SurveyYear=$P{Year}
) x group by District, genderCode, toiUse]]>
	</queryString>
	<field name="dName" class="java.lang.String"/>
	<field name="genderCode" class="java.lang.String"/>
	<field name="toiUse" class="java.lang.String"/>
	<field name="Students" class="java.lang.Integer"/>
