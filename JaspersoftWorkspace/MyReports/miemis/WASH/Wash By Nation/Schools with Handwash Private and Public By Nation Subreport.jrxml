	<parameter name="Year" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2019]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[-- Repointed to warehouse.WashHandwashCombinedSchoolDimension (layered handwash refactor):
-- instrument precedence + SoapWaterStatus crosswalk + JMP derivation live in the view; the
-- IF(inspection)/ELSE(census) is gone. Replaces TempWashCoreSurveyData + TempHygieneSurvey.
select AuthorityGovt as schLandOwner, case SoapWaterStatus when 'Water and soap' then 1 when 'Water only' then 2 when 'Soap only' then 3 when 'Neither' then 4 else 5 end as titleOrder,
  'Handwash with ' + SoapWaterStatus as HandWashType, COUNT(distinct schNo) as 'Total Schools'
from warehouse.WashHandwashCombinedSchoolDimension
where SurveyYear=$P{Year} and SoapWaterStatus is not null
group by AuthorityGovt, SoapWaterStatus]]>
	</queryString>
